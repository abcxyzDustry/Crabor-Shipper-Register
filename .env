# ══════════════════════════════════════
#   CRABOR – Environment Variables
#   Copy file này thành .env và điền vào
# ══════════════════════════════════════

# ── MongoDB Atlas ──
# Lấy từ: https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/crabor?retryWrites=true&w=majority

# ── App ──
NODE_ENV=development
PORT=3001

# ── Session ──
SESSION_SECRET=crabor-super-secret-key-doi-ngay

# ── Admin ──
# Key này dùng để gọi API /api/admin/*
ADMIN_SECRET_KEY=crabor-admin-key-2025-doi-ngay
ADMIN_DEFAULT_PASS=Crabor@2025

# ── ESMS.vn (SMS OTP) ──
# Đăng ký tại: https://esms.vn
# Vào: Tài khoản → API Key
ESMS_API_KEY=your_esms_api_key_here
ESMS_SECRET_KEY=your_esms_secret_key_here

# ══════════════════════════════════════
#   HƯỚNG DẪN SETUP
# ══════════════════════════════════════
#
# 1. MongoDB Atlas (miễn phí):
#    - Vào https://cloud.mongodb.com
#    - Tạo cluster miễn phí (M0)
#    - Tạo user database
#    - Whitelist IP 0.0.0.0/0
#    - Copy connection string vào MONGODB_URI
#
# 2. ESMS.vn (SMS OTP):
#    - Đăng ký tại https://esms.vn
#    - Nạp tối thiểu 200k
#    - Vào mục API → lấy ApiKey + SecretKey
#    - Giá: ~220đ/SMS
#
# 3. Chạy server:
#    npm install express mongoose cors axios dotenv
#    node shipper-server.js
#
# 4. Test gửi OTP (dev mode):
#    OTP sẽ hiện ra trong console thay vì gửi SMS thật
#    NODE_ENV=development → log OTP ra console
#    NODE_ENV=production  → gửi SMS thật qua ESMS

# ── ESMS Callback (tuỳ chọn) ──
# URL nhận kết quả gửi tin từ ESMS
# ESMS_CALLBACK_URL=https://yourserver.com/api/esms/callback
